# Production credentials for `pnpm ship` and `pnpm prod` — copy to .env.ship
# (git-ignored). Keep .env itself pointed at local SQLite dev; running the dev
# server against the production database is how data gets destroyed.

DATABASE_ADAPTER=postgres
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.aws.neon.tech/neondb?sslmode=require

# Vercel → Storage → your Blob store → the read-write token. Required so the
# production seed uploads media to Blob instead of your local disk.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXX

# Production admin credentials for the (convergent, idempotent) seed.
SEED_ADMIN_USERNAME=chancellor
SEED_ADMIN_PASSWORD=use-a-strong-password-here

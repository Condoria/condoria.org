{
  "name": "condoria-cms",
  "version": "1.0.0",
  "description": "Self-hosted CMS and public site for the Nation of Condoria (Rulercraft)",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "assets:mc": "node scripts/fetch-mc-assets.mjs",
    "dev": "node scripts/fetch-mc-assets.mjs && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "node scripts/fetch-mc-assets.mjs && cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "typecheck": "tsc --noEmit",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "prod": "node scripts/prod.mjs",
    "ship": "node scripts/ship.mjs",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation payload run src/seed/index.ts",
    "test:litematic": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/test-litematic.ts",
    "test:uvlock": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/test-uvlock.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.2",
    "@payloadcms/db-sqlite": "3.85.2",
    "@payloadcms/next": "3.85.2",
    "@payloadcms/richtext-lexical": "3.85.2",
    "@payloadcms/storage-vercel-blob": "3.85.2",
    "@payloadcms/ui": "3.85.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.3.0",
    "cross-env": "^7.0.3",
    "deepslate": "^0.26.0",
    "dotenv": "16.4.7",
    "gl-matrix": "^3.4.4",
    "graphql": "^16.8.1",
    "nbtify": "^2.2.0",
    "next": "16.2.6",
    "payload": "3.85.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.2",
    "three": "0.180.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.180.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "sass": "^1.86.3",
    "tailwindcss": "^4.1.11",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^10 || ^11"
  }
}

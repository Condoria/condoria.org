# ── Core ────────────────────────────────────────────────────────────────────
# Long random string used to sign auth tokens. REQUIRED in production.
# Generate one:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public origin of the site (no trailing slash).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Database ────────────────────────────────────────────────────────────────
# "sqlite"   → local file database, zero setup (default for local dev)
# "postgres" → production database (Neon). See README for the migration caveat.
DATABASE_ADAPTER=sqlite

# sqlite:   file URL, e.g. file:./condoria.db
# postgres: Neon connection string, e.g.
#           postgresql://USER:PASSWORD@ep-xxxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=file:./condoria.db

# ── File storage (production) ───────────────────────────────────────────────
# When set, media uploads are stored in Vercel Blob instead of the local
# ./media directory. Leave unset for local dev.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXX

# ── Seed script (`pnpm seed`) ───────────────────────────────────────────────
# Credentials for the first admin user. CHANGE THE PASSWORD after first login.
# The .example domain is IANA-reserved and can never receive real mail (no
# email adapter is configured anyway — Payload logs emails to the console).
SEED_ADMIN_EMAIL=admin@condoria.example
SEED_ADMIN_PASSWORD=change-me-immediately
